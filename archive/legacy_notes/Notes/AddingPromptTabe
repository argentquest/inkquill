class Prompt(Base):
    """
    SQLAlchemy ORM Model representing a reusable Prompt.
    Each prompt has a title, content, an active status, a type, a reason for its use, and an optional comment.
    It is created by a user and can be updated, tracking the last updater.
    Prompts are not deleted when the creating user is deleted (user_id becomes NULL).
    """
    __tablename__ = "prompts"

    # --- Table Columns ---

    id: Mapped[int] = mapped_column(Integer, primary_key=True, index=True)

    # Title of the prompt, max 200 characters, indexed for searching.
    title: Mapped[str] = mapped_column(String(200), index=True, nullable=False)

    # PromptContent: The actual text of the prompt. Using Text for large content.
    prompt_content: Mapped[str] = mapped_column(Text, nullable=False)

    # ReasonToUse: Explains why or when this prompt is useful. Using Text for potentially detailed explanations.
    reason_to_use: Mapped[Optional[str]] = mapped_column(Text, nullable=True)

    # Comment: Optional additional notes or comments about the prompt.
    comment: Mapped[Optional[str]] = mapped_column(Text, nullable=True) # New field

    # IsActive: Boolean flag to activate/deactivate the prompt. Defaults to True.
    is_active: Mapped[bool] = mapped_column(Boolean, default=True, nullable=False)

    # PromptType: Uses the Python enum `PromptTypeEnum`.
    prompt_type: Mapped[PromptTypeEnum] = mapped_column(
        SQLAlchemyEnum(
            PromptTypeEnum,
            name="prompt_type_enum", # Name of the ENUM type in PostgreSQL
            create_type=True,       # Instruct SQLAlchemy to create the ENUM type in the DB
            native_enum=True        # Use PostgreSQL's native ENUM type
        ),
        nullable=False,
        index=True
    )

    # user_id: Foreign key linking this prompt to the 'id' column in the 'users' table.
    # This represents the original creator of the prompt.
    # Made nullable=True to allow setting to NULL if the user is deleted.
    user_id: Mapped[Optional[int]] = mapped_column(Integer, ForeignKey("users.id", ondelete="SET NULL"), nullable=True)

    # last_updated_by_user_id: Foreign key linking to the user who last updated this prompt.
    # Already nullable. Ensure ON DELETE SET NULL at DB level.
    last_updated_by_user_id: Mapped[Optional[int]] = mapped_column(Integer, ForeignKey("users.id", ondelete="SET NULL"), nullable=True)

    # Timestamps
    created_at: Mapped[DateTime] = mapped_column(DateTime(timezone=True), server_default=func.now())
    updated_at: Mapped[DateTime] = mapped_column(DateTime(timezone=True), server_default=func.now(), onupdate=func.now())

    # --- Relationships ---
    # Relationship to the User model who created this prompt.
    # This relationship will become None if the user is deleted and user_id is set to NULL.
    owner: Mapped[Optional["User"]] = relationship("User", foreign_keys=[user_id], back_populates="prompts")

    # Relationship to the User model who last updated this prompt.
    last_updated_by: Mapped[Optional["User"]] = relationship("User", foreign_keys=[last_updated_by_user_id])
    # No back_populates specified here for last_updated_by, meaning it's a one-way query from Prompt.
    # If User model needs to list prompts they updated, add a corresponding relationship there.

    def __repr__(self):
        # Ensure self.prompt_type is not None before accessing .value
        prompt_type_value = self.prompt_type.value if self.prompt_type else "UNKNOWN_TYPE"
        return f"<Prompt(id={self.id}, title='{self.title}', type='{prompt_type_value}', owner_id={self.user_id})>"

