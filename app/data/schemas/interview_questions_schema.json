{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Interview Questions Schema",
  "description": "Schema for validating interview question JSON files",
  "properties": {
    "interview_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_]+$",
      "minLength": 3,
      "maxLength": 100,
      "description": "Unique identifier for the interview"
    },
    "interview_title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Human-readable title for the interview"
    },
    "interview_description": {
      "type": "string",
      "maxLength": 500,
      "description": "Description of the interview purpose"
    },
    "show_progress": {
      "type": "boolean",
      "default": true,
      "description": "Whether to show progress indicator"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_]+$",
            "minLength": 3,
            "maxLength": 100
          },
          "order": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "question": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "subtitle": {
            "type": "string",
            "maxLength": 200
          },
          "purpose": {
            "type": "string",
            "maxLength": 1000
          },
          "ui_type": {
            "type": "string",
            "enum": ["single_choice", "multiple_choice", "text_input"]
          },
          "display_type": {
            "type": "string",
            "enum": [
              "button_cards", 
              "button_cards_with_tooltip", 
              "large_button_cards_with_icons", 
              "modal_popup", 
              "textarea"
            ]
          },
          "required": {
            "type": "boolean",
            "default": true
          },
          "skip_button_text": {
            "type": "string",
            "maxLength": 50
          },
          "min_selections": {
            "type": "integer",
            "minimum": 0,
            "maximum": 20
          },
          "max_length": {
            "type": "integer",
            "minimum": 10,
            "maximum": 10000
          },
          "rows": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "placeholder": {
            "type": "string",
            "maxLength": 200
          },
          "modal_content": {
            "type": "object",
            "properties": {
              "title": {"type": "string", "maxLength": 100},
              "description": {"type": "string", "maxLength": 1000}
            }
          },
          "options": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_]+$",
                  "minLength": 1,
                  "maxLength": 100
                },
                "label": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200
                },
                "value": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_]+$",
                  "minLength": 1,
                  "maxLength": 100
                },
                "tooltip": {
                  "type": "string",
                  "maxLength": 500
                },
                "description": {
                  "type": "string",
                  "maxLength": 300
                },
                "icon": {
                  "type": "string",
                  "pattern": "^(fas|fab|far|fal|fad)\\s+fa-[a-zA-Z0-9\\-]+$",
                  "maxLength": 100
                },
                "route": {
                  "type": "string",
                  "pattern": "^/[a-zA-Z0-9/_\\-]*$",
                  "maxLength": 200
                },
                "action": {
                  "type": "string",
                  "enum": ["redirect", "continue", "modal"]
                }
              },
              "required": ["id", "label", "value"],
              "additionalProperties": false
            }
          }
        },
        "required": ["id", "order", "question", "ui_type", "required"],
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {"ui_type": {"const": "text_input"}}
            },
            "then": {
              "not": {"required": ["options"]}
            }
          },
          {
            "if": {
              "properties": {"ui_type": {"enum": ["single_choice", "multiple_choice"]}}
            },
            "then": {
              "required": ["options"]
            }
          },
          {
            "if": {
              "properties": {"required": {"const": false}}
            },
            "then": {
              "properties": {
                "skip_button_text": {"type": "string"}
              }
            }
          }
        ]
      }
    }
  },
  "required": ["interview_id", "interview_title", "questions"],
  "additionalProperties": false
}