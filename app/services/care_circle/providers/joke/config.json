{
    "name": "Daily Joke",
    "description": "A light-hearted joke to bring a smile to your day.",
    "technical_summary": "Fetches random safe-mode jokes from JokeAPI v2. Falls back to a stored joke if API fails.",
    "api_url": "https://v2.jokeapi.dev/joke/Any?safe-mode&type=single",
    "fallback": "Why did the scarecrow win an award? Because he was outstanding in his field!",
    "difficulty": {
        "default": "easy",
        "easy": {
            "style": "pun",
            "max_length": 100,
            "categories": [
                "Pun",
                "Misc"
            ]
        },
        "medium": {
            "style": "classic",
            "max_length": 200,
            "categories": [
                "Misc",
                "Christmas"
            ]
        },
        "hard": {
            "style": "wordplay",
            "max_length": 400,
            "categories": [
                "Any"
            ]
        }
    },
    "grid_width": 4,
    "grid_height": 2,
    "common": true,
    "llm": false
}
