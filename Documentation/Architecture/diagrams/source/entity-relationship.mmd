    %% Core User and Authentication
    User {
        int id PK
        string username UK
        string email UK
        string hashed_password
        string display_name
        string auth_provider
        string provider_id UK
        json provider_data
        string profile_picture_url
        boolean is_active
        boolean is_admin
        json interview_data
        boolean bonus1
        boolean bonus2
        boolean bonus3
        timestamp created_at
        timestamp updated_at
    }
    
    UserAccount {
        int id PK
        int user_id FK
        decimal balance_coins
        decimal total_earned_coins
        decimal total_spent_coins
        timestamp created_at
        timestamp updated_at
    }
    
    UserTransaction {
        int id PK
        int user_id FK
        string transaction_type
        decimal amount_coins
        string description
        json metadata
        timestamp created_at
    }
    
    UserActivity {
        uuid id PK
        int user_id FK
        string activity_type
        string endpoint
        string method
        json request_data
        json response_data
        int status_code
        int duration_ms
        timestamp created_at
    }
    
    %% World Building Domain
    World {
        int id PK
        string name
        text description
        text short_description
        json world_builder_data
        int user_id FK
        text image_prompt_definition
        string image_blob_path
        int current_image_id FK
        boolean is_free_chat_enabled
        boolean is_shadow
        timestamp created_at
        timestamp updated_at
    }
    
    Character {
        int id PK
        string name
        string gender
        string species
        text description
        text personality_traits
        text backstory
        text image_prompt_definition
        string image_blob_path
        int world_id FK
        int current_location_id FK
        text placement_note
        int current_image_id FK
        int importance_rating
        text relationships
        json core_motivations
        json physical_attributes
        json key_relationships
        string genre
        json genre_specific_answers
        text generated_narrative
        boolean is_ai_generated
        text next_quest_scenario
        text first_meeting_message
        string age_category
        string profession
        text short_backstory
        text visual_prompt
        json narrative_filter_results
        timestamp created_at
        timestamp updated_at
    }
    
    Location {
        int id PK
        string name
        text description
        string location_type
        text image_prompt_definition
        string image_blob_path
        int world_id FK
        int current_image_id FK
        int importance_rating
        json physical_attributes
        text generated_narrative
        boolean is_ai_generated
        timestamp created_at
        timestamp updated_at
    }
    
    LoreItem {
        int id PK
        string title
        text content
        string lore_type
        text image_prompt_definition
        string image_blob_path
        int world_id FK
        int current_image_id FK
        int importance_rating
        text generated_narrative
        boolean is_ai_generated
        timestamp created_at
        timestamp updated_at
    }
    
    LocationConnection {
        int from_location_id PK,FK
        int to_location_id PK,FK
        string connection_type
        text description
        boolean is_bidirectional
        int travel_time_minutes
        string difficulty_level
    }
    
    WorldRole {
        int id PK
        int world_id FK
        string role_name
        text description
        json permissions
        timestamp created_at
    }
    
    %% Story Structure Domain
    Story {
        int id PK
        string title
        text short_description
        text ai_summary
        int user_id FK
        int world_id FK
        string story_type
        string story_genre
        string story_tone
        string primary_conflict_type
        text image_prompt_definition
        string image_blob_path
        int current_image_id FK
        timestamp created_at
        timestamp updated_at
    }
    
    Act {
        int id PK
        string title
        text description
        int story_id FK
        int act_number
        text narrative_text
        text act_summary
        text ai_summary
        text image_prompt_definition
        string image_blob_path
        int current_image_id FK
        timestamp created_at
        timestamp updated_at
    }
    
    Scene {
        int id PK
        string title
        text description
        int act_id FK
