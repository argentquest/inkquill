    %% AI and Generated Content
    AIModelConfiguration {
        int id PK
        string model_name
        string display_name
        string provider
        string model_type
        decimal user_price_input_usd_pm
        decimal user_price_output_usd_pm
        boolean is_active
        json configuration
        timestamp created_at
        timestamp updated_at
    }
    
    AICallLog {
        int id PK
        string job_id
        int user_id FK
        int model_config_id FK
        text input_prompt
        string model_name
        string call_type
        int object_id
        int prompt_tokens
        int completion_tokens
        int total_tokens
        decimal calculated_cost_usd
        int duration_ms
        timestamp created_at
    }
    
    GeneratedImage {
        int id PK
        string element_type
        int associated_element_id
        int user_id FK
        string prompt_used
        string image_size
        string provider
        string model_used
        string blob_path
        string status
        string error_message
        int ai_cost_log_id FK
        timestamp created_at
        timestamp updated_at
    }
    
    %% Document Management
    UploadedDocument {
        int id PK
        string filename
        string original_filename
        string content_type
        int file_size_bytes
        string source_element_type
        int source_element_id
        int world_id FK
        int user_id FK
        string processing_status
        json metadata
        timestamp created_at
        timestamp updated_at
    }
    
    %% Community Features
    ForumCategory {
        int id PK
        string name
        text description
        string slug
        int sort_order
        boolean is_active
        timestamp created_at
        timestamp updated_at
    }
    
    ForumThread {
        int id PK
        string title
        text description
        int category_id FK
        int user_id FK
        int world_id FK
        int story_id FK
        boolean is_pinned
        boolean is_locked
        int view_count
        int post_count
        timestamp last_activity_at
        timestamp created_at
        timestamp updated_at
    }
    
    ForumPost {
        int id PK
        text content
        int thread_id FK
        int user_id FK
        int parent_post_id FK
        boolean is_deleted
        int vote_score
        timestamp created_at
        timestamp updated_at
    }
    
    ForumVote {
        int id PK
        int post_id FK
        int user_id FK
        int vote_value
        timestamp created_at
    }
    
    ForumSubscription {
        int id PK
        int thread_id FK
        int user_id FK
        boolean email_notifications
        timestamp created_at
    }
    
    %% Publishing and Social
    PublishedStory {
        int id PK
        int story_id FK
        int user_id FK
        string published_url
        string filename
        string title
        text description
        int word_count
        boolean is_public
        int view_count
        decimal average_rating
        int rating_count
        timestamp created_at
        timestamp updated_at
    }
    
    StoryComment {
        int id PK
        int published_story_id FK
        int user_id FK
        text content
        timestamp created_at
        timestamp updated_at
    }
    
    StoryRating {
        int id PK
        int published_story_id FK
        int user_id FK
        int rating_value
        timestamp created_at
        timestamp updated_at
    }
    
    SocialShare {
        uuid id PK
        int user_id FK
        string platform
        string content_type
        int content_id
        string share_url
        int coins_earned
        timestamp created_at
    }
    
