[flake8]
max-line-length = 127
extend-ignore = E203, W503
exclude = 
    .git,
    __pycache__,
    venv,
    .venv,
    .eggs,
    *.egg,
    build,
    dist,
    migrations,
    .pytest_cache,
    node_modules
max-complexity = 10
per-file-ignores =
    __init__.py:F401
    app/models/*.py:F401
    app/schemas/*.py:F401