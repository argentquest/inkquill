# ============================================================
#  Ink & Quill — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Local-first application configuration template.
# ============================================================

# --- Application ---
APP_PROJECT_NAME="Ink & Quill"
APP_ENV=development          # development | staging | production
APP_URL=http://localhost:8000

# --- Database (PostgreSQL) ---
# For local dev you can run Postgres in Docker:
#   docker compose up db
POSTGRES_USER=inkquill
POSTGRES_PASSWORD=changeme
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=inkquill_db

# Optional clone targets when using scripts/clone_postgres_db.ps1
POSTGRES_TEST_DB=inkquill_db_test
POSTGRES_PROD_DB=inkquill_db_prod

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ============================================================
#  LLM Provider  (choose ONE — OPENROUTER recommended)
# ============================================================
ACTIVE_LLM_PROVIDER=OPENROUTER          # OPENROUTER | OPENAI

# --- OpenRouter (free tier available, 200+ models) ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=InkAndQuill
# Free/cheap models to start with:
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_PREMIUM_MODEL=openai/gpt-4o
# Alternatives (pick any from https://openrouter.ai/models):
# OPENROUTER_DEFAULT_MODEL=mistralai/mistral-7b-instruct:free
# OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_DEFAULT_MODEL=google/gemini-flash-1.5

# --- Standard OpenAI (alternative to OpenRouter) ---
# OPENAI_API_KEY=sk-REPLACE_ME
# DEFAULT_GENERATION_MODEL_NAME=gpt-4o-mini

# ============================================================
#  Embeddings  (LOCAL — no API key, downloads on first run)
# ============================================================
# Models are cached in ~/.cache/huggingface after first download.
# all-MiniLM-L6-v2 → 384-dim, fast, ~90 MB download
# all-mpnet-base-v2 → 768-dim, more accurate, ~420 MB download
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================
#  Vector Database  (LOCAL ChromaDB — no cloud needed)
# ============================================================
VECTOR_DB_PATH=./data/chromadb
VECTOR_DB_COLLECTION_NAME=rag_documents

# ============================================================
#  File Storage  (LOCAL by default — no cloud needed)
# ============================================================
LOCAL_STORAGE_BASE_PATH=./data/uploads
LOCAL_STORAGE_RAG_DOCS_PATH=rag_docs
LOCAL_STORAGE_PUBLISHED_STORIES_PATH=published
LOCAL_STORAGE_GENERATED_IMAGES_PATH=generated_images
LOCAL_STORAGE_BLOG_MEDIA_PATH=blog_media

# ============================================================
#  Image Generation
# ============================================================
# Options: DALLE3 (requires OPENAI_API_KEY) | RUNPOD | NONE
ACTIVE_IMAGE_PROVIDER=DALLE3
DEFAULT_IMAGE_SIZE=1024x1024

# OpenAI image generation (gpt-image-1 — latest model as of 2025)
# Requires a standard OpenAI key (not OpenRouter)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_IMAGE_MODEL=gpt-image-1

# RunPod (self-hosted Flux/SDXL — optional, costs per GPU second)
# RUNPOD_API_KEY=rpa_REPLACE_ME
# RUNPOD_ENDPOINT_ID=REPLACE_ME
# ACTIVE_IMAGE_PROVIDER=RUNPOD

# ============================================================
#  Email  (optional — leave blank to disable email features)
# ============================================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@email.com
# SMTP_PASSWORD=REPLACE_ME
# FROM_EMAIL=your@email.com
# FROM_NAME=Ink & Quill
EMAIL_TEST_MODE=true
# EMAIL_TEST_ADDRESS=dev@yourdomain.com

# ============================================================
#  Google OAuth  (optional — leave blank to disable)
# ============================================================
OAUTH_ENABLED=false
GOOGLE_OAUTH_ENABLED=false
# GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME

# ============================================================
#  Google Analytics  (optional)
# ============================================================
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_ANALYTICS_CONSENT_MODE=true
COOKIE_CONSENT_REQUIRED=true

# ============================================================
#  CORS
# ============================================================
BACKEND_CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000","http://localhost:3001","http://127.0.0.1:3001","http://localhost:3002","http://127.0.0.1:3002"]

# ============================================================
#  RAG Settings
# ============================================================
DEFAULT_CHUNK_SIZE_TOKENS=1000
DEFAULT_CHUNK_OVERLAP_TOKENS=100
RAG_RETRIEVAL_TOP_K=3
RAG_WRITING_ASSISTANT_TOP_K=10
RAG_CHAT_TOP_K=7
RAG_MIN_RELEVANCE_SCORE=0.5   # lower threshold works better with local embeddings

# ============================================================
#  Care Circle / Imported DailyNewsletter Provider Support
# ============================================================
# Imported provider logs and generated payloads for care-circle workflows
CARE_CIRCLE_PROVIDER_LOG_DIR=./logs/care_circle/providers

# DailyNewsletter source app used SMTP_HOST; this repo uses SMTP_SERVER.
# DailyNewsletter source app used POSTGRES_URI; this repo uses POSTGRES_* fields above.

# ============================================================
#  Logging
# ============================================================
LOG_LEVEL_CONSOLE=INFO
LOG_LEVEL_FILE=DEBUG
APP_LOG_DIR=./logs
CLEAR_LOG_HANDLERS=true


