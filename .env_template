# --- CORS Origins ---
# A JSON-formatted string representing a list of allowed origins.
# For local development, allow your FastAPI app's origin and any frontend dev server origin.
# Example: BACKEND_CORS_ORIGINS='["http://localhost:8000", "http://127.0.0.1:8000", "http://localhost:3000"]'
# Using "*" is a wildcard, generally not recommended for production.
BACKEND_CORS_ORIGINS=["http://localhost:8000", "http://127.0.0.1:8000"]

# --- Optional: For maintest.py specific test container for blobs ---
# TEST_STORAGE_CONTAINER_NAME="maintest-blob-container"

SCENE_EXTRACTION_MAX_TOKENS=4000
SCENE_EXTRACTION_TEMPERATURE=0.2

# --- Logging Configuration ---
# Controls the verbosity of logs sent to the console.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL_CONSOLE="DEBUG"

# Controls the verbosity of logs sent to the log file (e.g., logs/app_backend.log).
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL_FILE="DEBUG"

# Directory where log files will be stored. Defaults to a 'logs' folder in the project root.
# Make sure this path is writable by the application.
# For Docker, this might be a mounted volume. For App Service, consider Azure's logging features.
APP_LOG_DIR="./logs"

# Whether to clear existing log handlers (e.g., from Uvicorn) before setting up custom ones.
# Set to "false" if you want to keep Uvicorn's default console logging and add file logging on top.
# Set to "true" for full control by the application's logging setup (recommended for consistency).
CLEAR_LOG_HANDLERS="true"

