# --- Application Core Settings ---
APP_PROJECT_NAME="AI Storytelling Assistant (Dev)"
APP_ENV="development" # Options: development, staging, production

# --- Google Analytics Configuration ---
# Set your Google Analytics 4 Measurement ID (e.g., "G-XXXXXXXXXX")
# Leave empty or comment out to disable Google Analytics
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# Enable Google Analytics Consent Mode (GDPR compliance)
# Set to false to disable consent mode (not recommended for EU users)
GOOGLE_ANALYTICS_CONSENT_MODE=true

# Require cookie consent banner
# Set to false to disable cookie consent banner
COOKIE_CONSENT_REQUIRED=true

# --- Database Configuration (Main Application) ---
