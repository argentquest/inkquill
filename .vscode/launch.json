{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend: Use This (stable debug)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host", "localhost",
                "--port", "8000",
                "--log-level", "debug"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "stopOnEntry": false
        },
        {
            "name": "Backend: Optional (reload, less stable)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host", "localhost",
                "--port", "8000",
                "--reload",
                "--log-level", "debug"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "stopOnEntry": false
        },
        {
            "name": "Frontend: Use This (Next.js dev)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev -- --port 3001",
            "cwd": "${workspaceFolder}/frontendv1"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Use This (stable backend + frontend)",
            "configurations": [
                "Backend: Use This (stable debug)",
                "Frontend: Use This (Next.js dev)"
            ],
            "stopAll": true
        },
        {
            "name": "Full Stack: Optional (reload backend + frontend)",
            "configurations": [
                "Backend: Optional (reload, less stable)",
                "Frontend: Use This (Next.js dev)"
            ],
            "stopAll": true
        }
    ]
}
