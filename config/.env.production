# Production Environment Configuration
# Copy this file and fill in the values for your production environment
# NEVER commit actual values to source control

# Database Configuration
DATABASE_URL=postgresql+asyncpg://username:password@server.postgres.database.azure.com/dbname

# Azure Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_CONTAINER_NAME=rag-documents

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_INDEX_NAME=rag-index

# OpenAI Configuration
OPENAI_API_TYPE=azure
OPENAI_API_BASE=https://your-openai.openai.azure.com/
OPENAI_API_VERSION=2024-02-15-preview
OPENAI_DEPLOYMENT_NAME=gpt-4

# Application Settings
SECRET_KEY=your-very-long-random-secret-key
ENVIRONMENT=production
DEBUG=False
ALLOWED_HOSTS=your-app.azurewebsites.net

# Security Settings
CORS_ORIGINS=https://your-app.azurewebsites.net
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/home/LogFiles/app.log

# Performance Settings
WORKERS=4
WORKER_TIMEOUT=120
KEEPALIVE=5